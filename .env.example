# Gmail account that sends booking emails (use an App Password, not your normal password)
GMAIL_USER=innocentphotos10@gmail.com

# 16-character Gmail App Password (no spaces)
GMAIL_APP_PASSWORD=

# Where booking inquiries are delivered
BOOKING_INBOX=innocentphotos10@gmail.com

# Optional: Google Search Console HTML tag verification (URL-prefix property only)
# Domain properties verify via DNS TXT in Cloudflare — see SEO-GOOGLE-SEARCH-CONSOLE.md
GOOGLE_SITE_VERIFICATION=
